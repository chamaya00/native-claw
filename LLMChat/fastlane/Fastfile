default_platform(:ios)

platform :ios do

  # ───────────────────────────────────────────
  # Generate .xcodeproj from project.yml
  # ───────────────────────────────────────────
  desc "Generate Xcode project using XcodeGen"
  lane :generate_project do
    Dir.chdir("..") do
      sh("xcodegen generate --spec project.yml")
    end
  end

  # ───────────────────────────────────────────
  # Build the app (no signing required for CI)
  # ───────────────────────────────────────────
  desc "Build the app"
  lane :build do
    generate_project

    gym(
      project: "LLMChat.xcodeproj",
      scheme: "LLMChat",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      skip_package_ipa: true,
      skip_archive: true,
      clean: true,
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO"
    )
  end

  # ───────────────────────────────────────────
  # Release archive proxy (no signing) — cheap stand-in for the deploy
  # ───────────────────────────────────────────
  # Exercises the same Release-config, generic-iOS-device archive path the
  # `beta` lane uses, but with signing disabled and no upload. Catches
  # Release-only compile/archive failures on a PR before a TestFlight run is
  # ever attempted. Mirror this with the "Archive for device (Release,
  # unsigned)" step in .github/workflows/build.yml so the two cannot drift.
  desc "Archive in Release config without signing (deploy proxy)"
  lane :archive_check do
    generate_project

    gym(
      project: "LLMChat.xcodeproj",
      scheme: "LLMChat",
      configuration: "Release",
      destination: "generic/platform=iOS",
      skip_package_ipa: true,
      skip_codesigning: true,
      clean: true,
      xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO"
    )
  end

  # ───────────────────────────────────────────
  # Run unit tests
  # ───────────────────────────────────────────
  desc "Run tests"
  lane :test do
    generate_project

    scan(
      project: "LLMChat.xcodeproj",
      scheme: "LLMChat",
      device: "iPhone 16",
      clean: true
    )
  end

  # ───────────────────────────────────────────
  # One-time setup: create certs & profiles
  # ───────────────────────────────────────────
  desc "Initialize Match and create App Store certificates and provisioning profiles"
  lane :setup_signing do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      app_identifier: ENV["APP_IDENTIFIER"],
      readonly: false,
      force_for_new_devices: true
    )
  end

  # ───────────────────────────────────────────
  # Upload to TestFlight
  # ───────────────────────────────────────────
  desc "Upload to TestFlight"
  lane :beta do
    # Set up App Store Connect API key for authentication
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )

    # Create a dedicated CI keychain so codesign never blocks waiting for
    # interactive keychain unlock (the default system keychain requires UI).
    keychain_name = "ci-signing.keychain"
    keychain_password = SecureRandom.hex(20)
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Sync certificates and provisioning profiles via match into the CI keychain
    match(
      type: "appstore",
      app_identifier: ENV["APP_IDENTIFIER"],
      readonly: true,
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    generate_project

    # Increment build number using latest TestFlight build
    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: "LLMChat.xcodeproj"
    )

    # Configure manual signing to use the match-provisioned profiles.
    #
    # Scope this to the LLMChat app target only. The MemoryKit/ToolsKit/AgentKit
    # framework targets do not support provisioning profiles — assigning one
    # makes Xcode 26 fail the archive with "<Target> does not support
    # provisioning profiles". Embedded frameworks are automatically re-signed
    # with the app's signing identity during the embed phase, so they need no
    # profile of their own.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "LLMChat.xcodeproj",
      team_id: ENV["APP_STORE_TEAM_ID"],
      code_sign_identity: "iPhone Distribution",
      profile_name: ENV["sigh_#{ENV['APP_IDENTIFIER']}_appstore_profile-name"],
      targets: ["LLMChat"]
    )

    gym(
      project: "LLMChat.xcodeproj",
      scheme: "LLMChat",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      xcargs: "DEVELOPMENT_TEAM='#{ENV['APP_STORE_TEAM_ID']}'"
    )

    pilot(
      distribute_external: false,
      notify_external_testers: false,
      changelog: ENV["RELEASE_NOTES"] || "Bug fixes and improvements"
    )
  ensure
    # Remove the temporary keychain regardless of success or failure
    delete_keychain(name: keychain_name) if keychain_name
  end

  # ───────────────────────────────────────────
  # Friendlier diagnostics for common, non-code failures
  # ───────────────────────────────────────────
  error do |lane, exception|
    message = exception.message.to_s

    # App Store Connect returns this whenever a legal agreement (Apple Developer
    # Program License Agreement, or the Paid/Free Apps Agreement) is unsigned or
    # expired. It is an account-level block, not a build problem — no Fastfile
    # change can bypass it, so surface clear remediation steps in the CI log.
    if message.include?("in-effect agreement") || message.include?("required agreement")
      UI.error("──────────────────────────────────────────────────────────────")
      UI.error("App Store Connect rejected the request: a required agreement is")
      UI.error("missing or has expired.")
      UI.error("")
      UI.error("This is an account-level block, not a code issue. To resolve:")
      UI.error("  1. Sign in to https://appstoreconnect.apple.com as the Account Holder.")
      UI.error("  2. Open Business > Agreements (and Membership in the Developer")
      UI.error("     portal) and accept any pending agreement.")
      UI.error("  3. Re-run this workflow.")
      UI.error("──────────────────────────────────────────────────────────────")

      # Drop a marker the deploy workflow can read so the resulting commit
      # status names this account-level block explicitly, instead of the
      # generic "deploy failed" text that reads like a code/build breakage.
      # (__dir__ is LLMChat/fastlane; the marker lands at LLMChat/.agreement_blocked.)
      begin
        File.write(
          File.expand_path("../.agreement_blocked", __dir__),
          "App Store Connect agreement missing or expired\n"
        )
      rescue StandardError => e
        UI.error("(could not write agreement-block marker: #{e.message})")
      end
    end
  end
end
